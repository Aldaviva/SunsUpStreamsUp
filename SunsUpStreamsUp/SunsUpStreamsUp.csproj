<Project Sdk="Microsoft.NET.Sdk.Worker">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <RuntimeIdentifiers>win-x64;win-arm64;linux-x64;linux-arm;linux-arm64;osx-x64;osx-arm64</RuntimeIdentifiers>
        <AssemblyName>sunsupstreamsup</AssemblyName>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <RollForward>latestMajor</RollForward>
        <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
        <Version>2.0.0</Version>
        <Authors>Ben Hutchison</Authors>
        <Copyright>© 2026 $(Authors)</Copyright>
        <Company>$(Authors)</Company>
        <SelfContained>false</SelfContained>
        <DebugType>embedded</DebugType>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.6" />
        <PackageReference Include="Microsoft.IdentityModel.JsonWebTokens" Version="8.17.0" />
        <PackageReference Include="NodaTime" Version="3.3.2" />
        <PackageReference Include="RuntimeUpgradeNotifier" Version="1.1.0" />
        <PackageReference Include="SolCalc" Version="1.0.2" />
        <PackageReference Include="ThrottleDebounce" Version="3.0.0-beta6" />
        <PackageReference Include="Unfucked.DateTime" Version="0.0.1-beta.5" />
        <PackageReference Include="Unfucked.DI" Version="0.0.1-beta.16" />
        <PackageReference Include="Unfucked.HTTP" Version="0.0.1-beta.30" />
        <PackageReference Include="Unfucked.OBS" Version="0.0.1-beta.3" />
    </ItemGroup>

    <ItemGroup>
        <None Include="..\Readme.md;..\.github*\**" />
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="Tests;Performance" />
    </ItemGroup>

</Project>